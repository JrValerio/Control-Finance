PORT=3001
NODE_ENV=development
# Build identity for /health (optional)
# APP_VERSION=1.6.3
# APP_COMMIT=2eb3f64
# Render auto-populates RENDER_GIT_COMMIT (version fallback: sha-<commit-curto>)
# JWT hardening:
# - production exige segredo explicito, nao-placeholder e com 32+ caracteres
# - local/test (sem valor) usa fallback deterministico somente para desenvolvimento
JWT_SECRET=troque-isto-por-um-segredo-com-32-ou-mais-caracteres
JWT_EXPIRES_IN=24h
TRUST_PROXY=1
# Exemplo local:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/control_finance
# Exemplo cloud:
# DATABASE_URL=postgresql://user:password@host:5432/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/control_finance
# Force SSL when required by managed Postgres providers (Render external URL, etc.)
# DB_SSL=true
DB_SSL=false
# Aceita lista separada por virgula (ex.: local + Vercel)
# CORS_ORIGIN=http://localhost:5173,https://control-finance-react-tail-wind.vercel.app
CORS_ORIGIN=http://localhost:5173
# Stripe guardrail:
# - production requires sk_live_*
# - non-production requires sk_test_*
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PRICE_ID_PRO=price_...
# STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:5173/app/settings/billing?checkout=success
# STRIPE_CHECKOUT_CANCEL_URL=http://localhost:5173/app/settings/billing?checkout=cancel
# Billing entitlement policy
# BILLING_PAST_DUE_GRACE_DAYS=3
# Paywall bypass -- DEV / STAGING ONLY. Ignored when NODE_ENV=production.
# Set PAYWALL_BYPASS_ENABLED=true and list emails to grant full PRO access without a subscription.
PAYWALL_BYPASS_ENABLED=false
# PAYWALL_BYPASS_EMAILS=dev@example.com,qa@example.com
# Ops endpoint guard (non-production only; required for /ops/force-plan)
# OPS_TOKEN=troque-isto-por-um-token-forte
# Login hardening
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=20
AUTH_BRUTE_FORCE_WINDOW_MS=900000
AUTH_BRUTE_FORCE_MAX_ATTEMPTS=5
AUTH_BRUTE_FORCE_LOCK_MS=900000
# AI Insight (Claude Haiku via Anthropic SDK)
# Obtenha em: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-...
# Rate limit: chamadas ao /ai/insight por usuário (padrão: 10 calls / 10 min)
# AI_RATE_LIMIT_MAX=10
# AI_RATE_LIMIT_WINDOW_MS=600000
# Central do Leão (IRPF)
# Storage adapter policy (AUD-003 fase B)
# Supported values: local, s3
# Em producao, TAX_DOCUMENTS_STORAGE_ADAPTER deve ser s3.
# TAX_DOCUMENTS_STORAGE_ADAPTER=s3
# Persistencia local (dev/test ou janela controlada de legado)
# TAX_DOCUMENTS_STORAGE_DIR=/var/data/control-finance/tax-documents
# Configuracao remota obrigatoria quando TAX_DOCUMENTS_STORAGE_ADAPTER=s3
# TAX_DOCUMENTS_REMOTE_BUCKET=control-finance-tax-documents
# TAX_DOCUMENTS_REMOTE_REGION=us-east-1
# Opcional para S3 compativel (R2/MinIO/etc.)
# TAX_DOCUMENTS_REMOTE_ENDPOINT=https://<endpoint>
# TAX_DOCUMENTS_REMOTE_FORCE_PATH_STYLE=false
# Credenciais opcionais (se omitidas, usa provider chain do ambiente)
# TAX_DOCUMENTS_REMOTE_ACCESS_KEY_ID=...
# TAX_DOCUMENTS_REMOTE_SECRET_ACCESS_KEY=...
# TAX_DOCUMENTS_REMOTE_SESSION_TOKEN=...
# Compatibilidade temporaria de leitura de legado local (remote-first)
# TAX_DOCUMENTS_LEGACY_LOCAL_READ_ENABLED=false
# TAX_DOCUMENTS_LEGACY_LOCAL_STORAGE_DIR=/var/data/control-finance/tax-documents
# Optional max upload size in bytes (default: 10 MB)
# TAX_DOCUMENT_MAX_FILE_SIZE_BYTES=10485760
# AUD-004: redige previews textuais sensiveis de raw_json.classification no momento da persistencia.
# true (default): remove textPreviewLines de tax_document_extractions.raw_json.classification
# false: rollback controlado para comportamento legado sem redacao
# Em producao, usar false apenas de forma excepcional, temporaria e com registro operacional.
# TAX_SENSITIVE_EXCERPT_REDACTION_ENABLED=true
